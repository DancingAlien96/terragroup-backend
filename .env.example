PORT=4000

# MySQL — usado por mysql2 (legacy, irá desapareciendo) y por Prisma
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=terragroup
DB_USER=root
DB_PASS=rootpassword
DATABASE_URL="mysql://root:rootpassword@127.0.0.1:3306/terragroup"

# JWT
JWT_SECRET=secretitosdeamor
JWT_EXPIRES_IN=7d

# Correo (Gmail App Password)
MAIL_USER=tu_correo@gmail.com
MAIL_PASS=tu_app_password
MAIL_FROM="TerraGroup <tu_correo@gmail.com>"

# URLs públicas (usadas por Recurrente para success_url/cancel_url)
FRONTEND_URL=https://terragroup.urbandata.app

# Recurrente (pasarela de pago del SaaS)
# Dashboard de Recurrente → Configuración → Llaves API
RECURRENTE_API_URL=https://app.recurrente.com/api
RECURRENTE_SECRET_KEY=sk_live_xxx
# whsec_* obtenido al crear el webhook en Recurrente apuntando a
# https://apiterragroup.urbandata.app/api/webhooks/recurrente
RECURRENTE_WEBHOOK_SECRET=whsec_xxx
# Monto en centavos ($2,000 USD = 200000)
RECURRENTE_MONTO_CENTS=200000
RECURRENTE_CURRENCY=USD
RECURRENTE_PRODUCT="TerraGroup — Licencia única"

# Plan asignado por defecto al registrar (modelo de pago único)
DEFAULT_PLAN_ID=1

# Sentry — error tracking. DSN del proyecto en sentry.io.
# Vacío = error tracking deshabilitado (no falla la app).
SENTRY_DSN=
# % de transacciones que se envían a Sentry (0.0–1.0). Default 0.1 = 10%.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Rate limiting — overrides opcionales (defaults razonables ya)
# RATE_LIMIT_LOGIN=10      # intentos de login por IP cada 15 min
# RATE_LIMIT_REGISTER=5    # registros por IP por hora
# RATE_LIMIT_WEBHOOK=120   # webhooks de Recurrente por minuto
